# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/multimodal_db"

# Object Storage Configuration
# Default below is for the local MinIO container started by docker-compose.yml.
# MinIO is S3-compatible, free, and needs no cloud account or card - it just
# runs locally next to Postgres. To switch to AWS S3 or Cloudflare R2 later,
# see the commented examples further down.
STORAGE_BUCKET_NAME="multimodal-ai-bucket"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_ENDPOINT_URL="http://localhost:9000"
STORAGE_REGION="us-east-1"
# MinIO has no dashboard wizard to create/publicize a bucket for you, so the
# backend does it automatically on startup when this is "true".
STORAGE_AUTO_PROVISION_BUCKET="true"
# Browser-facing URL for generated image links. Same host:port as the
# endpoint above, since MinIO serves objects directly over its API port.
STORAGE_PUBLIC_BASE_URL="http://localhost:9000/multimodal-ai-bucket"

# --- Cloudflare R2 alternative (uncomment and fill in if you have an account) ---
# STORAGE_ACCESS_KEY="your_r2_access_key"
# STORAGE_SECRET_KEY="your_r2_secret_key"
# STORAGE_ENDPOINT_URL="https://your-account-id.r2.cloudflarestorage.com"
# STORAGE_REGION="auto"
# STORAGE_PUBLIC_BASE_URL="https://pub-xxxxxxxxxxxx.r2.dev"
# STORAGE_AUTO_PROVISION_BUCKET="false"   # create the bucket via R2 dashboard instead

# --- AWS S3 alternative ---
# STORAGE_ENDPOINT_URL=""   # leave blank for AWS S3
# STORAGE_REGION="us-east-1"
# STORAGE_AUTO_PROVISION_BUCKET="false"   # create the bucket + policy via AWS console instead

# AI Service Providers
GEMINI_API_KEY="AQ..."
#ANTHROPIC_API_KEY="sk-ant-..."
STABILITY_API_KEY="sk-..."

# Optional overrides
VLM_MODEL="gemini-2.5-flash"
FRONTEND_ORIGIN="http://localhost:3000"
